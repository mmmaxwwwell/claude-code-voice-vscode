{
  "name": "claude-voice",
  "displayName": "Claude Voice",
  "description": "Conversational voice mode for the Claude Code VS Code extension",
  "version": "0.1.0",
  "publisher": "anthropics",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/claude-code-voice-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-voice.toggleListening",
        "title": "Claude Voice: Toggle Listening"
      },
      {
        "command": "claude-voice.downloadModel",
        "title": "Claude Voice: Download Model"
      },
      {
        "command": "claude-voice.checkDependencies",
        "title": "Claude Voice: Check Dependencies"
      },
      {
        "command": "claude-voice.pttStart",
        "title": "Claude Voice: Push-to-Talk Start"
      },
      {
        "command": "claude-voice.pttStop",
        "title": "Claude Voice: Push-to-Talk Stop"
      }
    ],
    "keybindings": [
      {
        "command": "claude-voice.pttStart",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "!claude-voice.pttActive"
      },
      {
        "command": "claude-voice.pttStop",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "claude-voice.pttActive"
      }
    ],
    "configuration": {
      "title": "Claude Voice",
      "properties": {
        "claude-voice.inputMode": {
          "type": "string",
          "default": "wakeWord",
          "enum": [
            "wakeWord",
            "pushToTalk",
            "continuousDictation"
          ],
          "enumDescriptions": [
            "Activate with wake word (\"hey claude\")",
            "Hold a keybinding to speak",
            "All speech is transcribed, command words delimit chunks"
          ],
          "description": "Active input mode"
        },
        "claude-voice.wakeWord": {
          "type": "string",
          "default": "hey_claude",
          "description": "openWakeWord model name"
        },
        "claude-voice.submitWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "send it",
            "go",
            "submit"
          ],
          "description": "Words that trigger transcript submission"
        },
        "claude-voice.cancelWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "never mind",
            "cancel"
          ],
          "description": "Words that discard current transcript"
        },
        "claude-voice.deliveryMode": {
          "type": "string",
          "default": "autoSubmit",
          "enum": [
            "autoSubmit",
            "pasteAndReview"
          ],
          "enumDescriptions": [
            "Automatically submit after typing",
            "Type text and leave cursor in input for review"
          ],
          "description": "How transcriptions are delivered to Claude Code"
        },
        "claude-voice.whisperModel": {
          "type": "string",
          "default": "base",
          "enum": [
            "tiny",
            "base",
            "small",
            "medium"
          ],
          "description": "Whisper model size for speech-to-text"
        },
        "claude-voice.pushToTalkKey": {
          "type": "string",
          "default": "ctrl+shift+space",
          "description": "Keybinding for push-to-talk mode"
        },
        "claude-voice.silenceTimeout": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "maximum": 10000,
          "description": "Milliseconds of silence before ending an utterance"
        },
        "claude-voice.maxUtteranceDuration": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Maximum single utterance duration in milliseconds"
        },
        "claude-voice.micDevice": {
          "type": "string",
          "default": "",
          "description": "Microphone device name (empty = system default)"
        },
        "claude-voice.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Show all log messages including debug",
            "Show info, warn, and error messages",
            "Show warn and error messages only",
            "Show error messages only"
          ],
          "description": "Minimum log level for the Claude Voice output channel"
        }
      }
    }
  },
  "scripts": {
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --coverage tests/unit/ts/",
    "test:integration": "vitest run --coverage tests/integration/",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/ out/ coverage/ *.vsix",
    "clean:all": "rm -rf node_modules/ .venv/ dist/ out/ coverage/ test-logs/ .pytest_cache/ .mypy_cache/ .ruff_cache/ *.vsix ~/.cache/claude-voice/models/",
    "check": "npm run lint && npm run typecheck && npm run test",
    "package": "npm run build && npx @vscode/vsce package",
    "install-local": "npm run package && code --install-extension claude-voice-$(node -p \"require('./package.json').version\").vsix",
    "uninstall-local": "code --uninstall-extension anthropics.claude-voice"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.0",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  }
}
